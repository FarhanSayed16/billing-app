@startuml BillPush_Stakeholders_Hierarchy

skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #333333
skinparam defaultFontName Inter
skinparam defaultFontSize 11
skinparam roundCorner 8
skinparam shadowing false

skinparam rectangle {
  BackgroundColor #F8F9FA
  BorderColor #DEE2E6
  FontColor #333333
  RoundCorner 8
}

skinparam note {
  BackgroundColor #FFFBEB
  BorderColor #FDE68A
  FontColor #333333
}

title BillPush  -  Stakeholder Hierarchy and Access Matrix

rectangle "SUPER ADMIN\n(Brand Owner / Platform Owner)" as SA #EDE9FE {
  rectangle "Create and Manage Stores" as SA1 #F5F3FF
  rectangle "Assign Store Admins" as SA2 #F5F3FF
  rectangle "Global Analytics (All Stores)" as SA3 #F5F3FF
  rectangle "Master Product Catalog" as SA4 #F5F3FF
  rectangle "Global Customer Database" as SA5 #F5F3FF
  rectangle "Loyalty Program Config" as SA6 #F5F3FF
  rectangle "WhatsApp Marketing Campaigns" as SA7 #F5F3FF
  rectangle "Audit Logs (System-Wide)" as SA8 #F5F3FF
  rectangle "Export Reports (CSV/Excel)" as SA9 #F5F3FF
}

rectangle "STORE ADMIN\n(Franchise Owner / Branch Manager)" as StA #DBEAFE {
  rectangle "Create and Manage Employees" as StA1 #EFF6FF
  rectangle "Store-Level Analytics" as StA2 #EFF6FF
  rectangle "View / Void Invoices" as StA3 #EFF6FF
  rectangle "Local Customer List" as StA4 #EFF6FF
  rectangle "View Inventory Levels" as StA5 #EFF6FF
  rectangle "Store Settings and Discounts" as StA6 #EFF6FF
  rectangle "Daily Summary Notifications" as StA7 #EFF6FF
}

rectangle "EMPLOYEE\n(Cashier / POS Operator)" as Emp #FEF3C7 {
  rectangle "POS Billing Screen" as Emp1 #FFFBEB
  rectangle "Barcode Scanner (Camera)" as Emp2 #FFFBEB
  rectangle "Customer Name and Number Entry" as Emp3 #FFFBEB
  rectangle "Generate and Send Invoice" as Emp4 #FFFBEB
  rectangle "Apply Loyalty Points" as Emp5 #FFFBEB
  rectangle "View Own Shift Bills" as Emp6 #FFFBEB
}

rectangle "CUSTOMER\n(End Consumer - No Login in Store)" as Cust #D1FAE5 {
  rectangle "Receive WhatsApp Invoice" as Cust1 #ECFDF5
  rectangle "Web Portal: Purchase History" as Cust2 #ECFDF5
  rectangle "Check Loyalty Points" as Cust3 #ECFDF5
  rectangle "Download Past Invoices (PDF)" as Cust4 #ECFDF5
  rectangle "WhatsApp Chatbot (POINTS/HELP)" as Cust5 #ECFDF5
}

SA -[#7C3AED]down-> StA : Creates and Oversees
StA -[#3B82F6]down-> Emp : Creates and Manages
Emp -[#F59E0B]down-> Cust : Bills and Serves

note right of SA
  Visibility: GLOBAL
  Sees ALL stores, employees,
  customers, and invoices.
end note

note right of StA
  Visibility: LOCAL
  Sees ONLY their own store.
  Cannot see other franchises.
end note

note right of Emp
  Visibility: MINIMAL
  POS screen only.
  Own shift bills only.
end note

note right of Cust
  Visibility: OWN DATA
  Via WhatsApp and Web Portal.
  No app download needed.
end note

@enduml
