@startuml BillPush_Complete_Billing_Flow

skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #333333
skinparam defaultFontName Inter
skinparam defaultFontSize 11
skinparam shadowing false

skinparam activity {
  BackgroundColor #F8F9FA
  BorderColor #DEE2E6
  FontColor #333333
  RoundCorner 8
  DiamondBackgroundColor #EDE9FE
  DiamondBorderColor #C4B5FD
  DiamondFontColor #333333
}

title BillPush  -  Complete End-to-End Billing Flow

|#FEF3C7| Employee POS |
|#DBEAFE| Backend API |
|#D1FAE5| WhatsApp Engine |
|#FCE7F3| Customer Web |

|Employee POS|
start
:Employee opens app\nSelects name and enters 4-digit PIN;
:POS Home Screen loads\nNew Bill or Recent Bills;
:Taps New Bill\nCustomer entry screen opens;
:Enters Customers Phone Number\n10-digit WhatsApp number;

|Backend API|
:Customer Lookup Query\nSELECT FROM customers\nWHERE phone = input;

if (Customer Exists?) then (YES)
  :Auto-fill Name\nWelcome back, Anita\nPoints: 230;
else (NO)
  :New Customer\nPrompt Employee for Name;
  |Employee POS|
  :Employee types Name\ne.g. Anita;
  |Backend API|
  :Create Customer Record\nINSERT INTO customers;
endif

|Employee POS|
:Build Cart;

if (Scan or Manual?) then (SCAN)
  :Open Phone Camera\nScan barcode on clothing tag;
  :Lookup Product from Catalog\nMatch barcode and add to cart;
else (MANUAL)
  :Search Product by name\nor enter custom item and price;
endif

:Add more items to cart\nRepeat scan or manual as needed;

:Review Bill\nSubtotal: 1398\nGST 5 percent: 70\nGrand Total: 1468;

if (Apply Loyalty Points?) then (YES)
  :Deduct Points\n230 pts = 115 off\nNew Total: 1353;
else (NO)
  :Continue with full amount;
endif

if (Apply Discount?) then (YES)
  :Apply Discount\nFlat or percentage;
else (NO)
  :No discount;
endif

:Press CONFIRM AND SEND\nBig green button;

|Backend API|
:Save Invoice to PostgreSQL\nGenerate Invoice Number\nGenerate Billing ID\nGenerate QR Code;

:Update Analytics Counters\nIncrement store daily revenue\nIncrement customer visit count;

:Calculate and Credit Loyalty\nINSERT INTO loyalty_ledger\nUPDATE customer points;

:Decrement Inventory\nUPDATE store_inventory\nSET quantity = quantity - 1;

:Write Audit Log\nINVOICE_CREATED by Employee\nat Store for Customer;

|WhatsApp Engine|
:Format WhatsApp Template\nInsert customer_name, store_name\ntotal_amount, invoice_url;

:POST to Meta Cloud API\nSend message template;

if (Delivery Success?) then (YES)
  :Mark SENT;
  :Customer receives message\non WhatsApp;
  :Webhook updates status\nDELIVERED then READ;
else (FAILED)
  :Mark FAILED\nQueue for retry (3 attempts);
endif

|Employee POS|
:Success Screen\nBill sent to Anita on WhatsApp\nStart New Bill button;

|Customer Web|
:Customer clicks invoice link\nOpens branded invoice page;
:View branded invoice\nLogo, Items, Taxes, QR Code\nDownload as PDF button;

|Employee POS|
stop

@enduml
