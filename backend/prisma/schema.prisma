generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id                     String    @id @default(uuid()) @db.Uuid
  name                   String
  logo_url               String?
  primary_color          String?
  gst_number             String?
  loyalty_points_per_100 Int       @default(1)
  loyalty_min_redemption Int       @default(100)
  loyalty_expiry_months  Int       @default(12)
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  stores                 Store[]
  users                  User[]
  customers              Customer[]
  products               Product[]
  invoices               Invoice[]
  audit_logs             AuditLog[]

  @@map("brands")
}

model Store {
  id          String   @id @default(uuid()) @db.Uuid
  brand_id    String   @db.Uuid
  name        String
  address     String
  city        String
  state       String
  gst_number  String?
  phone       String
  logo_url    String?
  brand_color String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  brand       Brand    @relation(fields: [brand_id], references: [id])
  users       User[]
  inventory   StoreInventory[]
  invoices    Invoice[]

  @@map("stores")
}

enum Role {
  SUPER_ADMIN
  STORE_ADMIN
  EMPLOYEE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  brand_id        String         @db.Uuid
  store_id        String?        @db.Uuid
  email           String?        @unique
  password_hash   String?
  name            String
  phone           String
  pin             String?
  role            Role
  approval_status ApprovalStatus @default(PENDING)
  is_active       Boolean        @default(true)
  last_login_at   DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  brand           Brand          @relation(fields: [brand_id], references: [id])
  store           Store?         @relation(fields: [store_id], references: [id])
  invoices        Invoice[]
  audit_logs      AuditLog[]

  @@map("users")
}

model Customer {
  id             String    @id @default(uuid()) @db.Uuid
  brand_id       String    @db.Uuid
  phone          String
  name           String
  total_visits   Int       @default(0)
  total_spend    Decimal   @default(0) @db.Decimal(10, 2)
  loyalty_points Int       @default(0)
  first_visit_at DateTime?
  last_visit_at  DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  brand          Brand     @relation(fields: [brand_id], references: [id])
  invoices       Invoice[]
  loyalty_ledger LoyaltyLedger[]

  @@unique([brand_id, phone])
  @@map("customers")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  brand_id    String   @db.Uuid
  name        String
  sku         String?
  barcode     String?
  category    String?
  base_price  Decimal  @db.Decimal(10, 2)
  tax_rate    Decimal  @db.Decimal(5, 2)
  image_url   String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  brand       Brand    @relation(fields: [brand_id], references: [id])
  inventory   StoreInventory[]
  invoice_items InvoiceItem[]

  @@map("products")
}

model StoreInventory {
  id                  String   @id @default(uuid()) @db.Uuid
  store_id            String   @db.Uuid
  product_id          String   @db.Uuid
  quantity            Int
  low_stock_threshold Int      @default(10)
  updated_at          DateTime @updatedAt

  store               Store    @relation(fields: [store_id], references: [id])
  product             Product  @relation(fields: [product_id], references: [id])

  @@map("store_inventory")
}

enum InvoiceStatus {
  ACTIVE
  PARTIALLY_REFUNDED
  FULLY_REFUNDED
}

model Invoice {
  id                      String   @id @default(uuid()) @db.Uuid
  invoice_number          String
  billing_id              String   @unique @db.VarChar(16)
  brand_id                String   @db.Uuid
  store_id                String   @db.Uuid
  customer_id             String?  @db.Uuid
  employee_id             String   @db.Uuid
  subtotal                Decimal  @db.Decimal(10, 2)
  tax_amount              Decimal  @db.Decimal(10, 2)
  discount_amount         Decimal  @default(0) @db.Decimal(10, 2)
  loyalty_points_redeemed Int      @default(0)
  loyalty_discount        Decimal  @default(0) @db.Decimal(10, 2)
  grand_total             Decimal  @db.Decimal(10, 2)
  loyalty_points_earned   Int      @default(0)
  status                  InvoiceStatus @default(ACTIVE)
  share_triggered         Boolean  @default(false)
  invoice_pdf_url         String?
  qr_code_url             String?
  created_at              DateTime @default(now())

  brand                   Brand    @relation(fields: [brand_id], references: [id])
  store                   Store    @relation(fields: [store_id], references: [id])
  customer                Customer? @relation(fields: [customer_id], references: [id])
  employee                User     @relation(fields: [employee_id], references: [id])
  items                   InvoiceItem[]
  loyalty_ledger          LoyaltyLedger[]

  @@map("invoices")
}

model InvoiceItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoice_id String   @db.Uuid
  product_id String?  @db.Uuid
  name       String
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  tax_rate   Decimal  @db.Decimal(5, 2)
  tax_amount Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)

  invoice    Invoice  @relation(fields: [invoice_id], references: [id])
  product    Product? @relation(fields: [product_id], references: [id])

  @@map("invoice_items")
}

enum LedgerType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
}

model LoyaltyLedger {
  id          String   @id @default(uuid()) @db.Uuid
  customer_id String   @db.Uuid
  invoice_id  String?  @db.Uuid
  type        LedgerType
  points      Int
  description String?
  created_at  DateTime @default(now())

  customer    Customer @relation(fields: [customer_id], references: [id])
  invoice     Invoice? @relation(fields: [invoice_id], references: [id])

  @@map("loyalty_ledger")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  brand_id    String   @db.Uuid
  user_id     String   @db.Uuid
  action      String
  target_type String
  target_id   String   @db.Uuid
  metadata    Json?
  ip_address  String?
  created_at  DateTime @default(now())

  brand       Brand    @relation(fields: [brand_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}
